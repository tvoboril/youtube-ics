# --- Calendar source ---
# Defaults to the configured public calendar. Prefer the calendar's PRIVATE "secret iCal
# address" — the public basic.ics is cached by Google (edits can lag hours), which delays
# last-minute cancellation detection.
# ICS_URL=https://calendar.google.com/calendar/ical/.../private-<token>/basic.ics
# ICS_CALENDAR_ID=c_...@group.calendar.google.com   # override the default calendar id

# --- Scheduling window ---
LOOKAHEAD_DAYS=14          # keep the next 2 weeks populated (1–14; hard-capped at 14)

# --- Typikon enrichment (tone / feast / saints / vespers rank) ---
# melkite-typikon liturgical-day JSON API base URL.
TYPIKON_API_URL=https://melkitetypikon.org

# --- YouTube OAuth (channel manager's consent; mint once via `youtube-ics auth`) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# ATEM's reusable RTMP stream key; resolved to a liveStream id for liveBroadcasts.bind.
YOUTUBE_STREAM_KEY=

# --- State ---
# DB_PATH=youtube_ics.sqlite   # SQLite store (set to a mounted volume in Docker)
