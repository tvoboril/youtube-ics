# --- Calendar source ---
# Prefer the calendar's PRIVATE "secret iCal address" — the public basic.ics is cached by
# Google (edits can lag hours), which delays last-minute cancellation detection.
# ICS_URL=https://calendar.google.com/calendar/ical/.../private-<token>/basic.ics
# ICS_CALENDAR_ID=c_...@group.calendar.google.com   # (public fallback if ICS_URL unset)

# --- Scheduling window ---
LOOKAHEAD_DAYS=14          # keep the next 2 weeks populated (1–14; hard-capped at 14)

# --- Typikon enrichment (tone / feast / saints / vespers rank) ---
PARISH=saintgeorge
TYPIKON_BASE_URL=https://melkitetypikon.org   # HTML scraper fallback (default source)
# Set to use the JSON API instead of scraping (retires the Great-Vespers heuristic).
# Local test server: http://localhost:3000 ; prod once the branch deploys.
# TYPIKON_API_URL=http://localhost:3000

# --- YouTube (write path — not yet wired) ---
# ATEM's reusable RTMP stream key; resolved to a liveStream id for liveBroadcasts.bind.
YOUTUBE_STREAM_KEY=
# OAuth: created once via `youtube-ics auth` (planned); refresh token stored as a secret.
# GOOGLE_OAUTH_REFRESH_TOKEN=
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
